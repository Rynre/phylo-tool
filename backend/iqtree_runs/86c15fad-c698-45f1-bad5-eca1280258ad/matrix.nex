FORMAT DATATYPE=STANDARD MISSING=? GAP=- SYMBOLS="01";
MATRIX
  Root 010100
  Taxon_1 111010
  Taxon_2 110011
  Taxon_3 011011
  Taxon_4 101100
  Taxon_5 000110
;
END;
